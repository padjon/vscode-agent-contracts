{
  "name": "agent-contracts",
  "displayName": "Agent Contracts",
  "description": "Workspace trust contracts for MCP and AI-assisted development in VS Code.",
  "version": "1.6.1",
  "publisher": "padjon",
  "icon": "resources/icon.png",
  "sponsor": {
    "url": "https://github.com/sponsors/padjon"
  },
  "keywords": [
    "mcp",
    "ai",
    "security",
    "verification",
    "policy",
    "trust"
  ],
  "galleryBanner": {
    "color": "#f4efe6",
    "theme": "light"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/padjon/vscode-agent-contracts.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agentContracts.analyzeWorkspace",
    "onCommand:agentContracts.analyzeChangedFiles",
    "onCommand:agentContracts.initializeContract",
    "onCommand:agentContracts.openReport",
    "onCommand:agentContracts.openGuide",
    "onCommand:agentContracts.addRecommendedVerification",
    "onCommand:agentContracts.protectSensitivePaths",
    "onCommand:agentContracts.applyPreset",
    "onCommand:agentContracts.applySafeFixes",
    "onCommand:agentContracts.allowObservedMcpHosts",
    "onCommand:agentContracts.allowObservedMcpRunnerTargets",
    "onView:agentContracts.findings"
  ],
  "main": "./out/src/extension.js",
  "scripts": {
    "clean": "rm -rf out",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -w -p ./",
    "test:unit": "npm run compile && node --test out/test/analyzer.test.js",
    "test:integration": "npm run compile && node ./out/test/run-integration.js",
    "test": "npm run test:unit && npm run test:integration",
    "package": "npx @vscode/vsce package",
    "prepublishOnly": "npm run compile"
  },
  "contributes": {
    "commands": [
      {
        "command": "agentContracts.analyzeWorkspace",
        "title": "Agent Contracts: Analyze Workspace"
      },
      {
        "command": "agentContracts.initializeContract",
        "title": "Agent Contracts: Initialize Contract"
      },
      {
        "command": "agentContracts.analyzeChangedFiles",
        "title": "Agent Contracts: Analyze Changed Files"
      },
      {
        "command": "agentContracts.openReport",
        "title": "Agent Contracts: Open Report"
      },
      {
        "command": "agentContracts.openGuide",
        "title": "Agent Contracts: How It Works"
      },
      {
        "command": "agentContracts.addRecommendedVerification",
        "title": "Agent Contracts: Add Recommended Verification"
      },
      {
        "command": "agentContracts.protectSensitivePaths",
        "title": "Agent Contracts: Protect Sensitive Paths"
      },
      {
        "command": "agentContracts.applyPreset",
        "title": "Agent Contracts: Apply Contract Preset"
      },
      {
        "command": "agentContracts.applySafeFixes",
        "title": "Agent Contracts: Apply Safe Fixes"
      },
      {
        "command": "agentContracts.allowObservedMcpHosts",
        "title": "Agent Contracts: Allow Observed MCP Hosts"
      },
      {
        "command": "agentContracts.allowObservedMcpRunnerTargets",
        "title": "Agent Contracts: Allow Observed Runner Targets"
      }
    ],
    "configuration": {
      "title": "Agent Contracts",
      "properties": {
        "agentContracts.contractFileName": {
          "type": "string",
          "default": ".agent-contract.json",
          "description": "Workspace-relative path to the trust contract file."
        },
        "agentContracts.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh findings automatically after saves to MCP or contract files."
        },
        "agentContracts.mcpConfigGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".vscode/mcp.json"
          ],
          "description": "Workspace-relative globs for MCP configuration files to analyze."
        },
        "agentContracts.sensitiveFileGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.env*",
            "**/*.pem",
            "**/*.key",
            "**/*.p12",
            "**/*.crt",
            "**/.npmrc",
            "**/.pypirc",
            "**/secrets*.json",
            "**/secrets*.yaml",
            "**/secrets*.yml",
            "**/secrets*.env"
          ],
          "description": "Glob patterns that should usually be covered by protected paths in the contract."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentContracts",
          "title": "Agent Contracts",
          "icon": "resources/shield.svg"
        }
      ]
    },
    "views": {
      "agentContracts": [
        {
          "id": "agentContracts.findings",
          "name": "Workspace Trust"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agentContracts.analyzeWorkspace",
          "when": "view == agentContracts.findings",
          "group": "navigation"
        },
        {
          "command": "agentContracts.openReport",
          "when": "view == agentContracts.findings",
          "group": "navigation"
        },
        {
          "command": "agentContracts.openGuide",
          "when": "view == agentContracts.findings",
          "group": "navigation"
        },
        {
          "command": "agentContracts.analyzeChangedFiles",
          "when": "view == agentContracts.findings",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
