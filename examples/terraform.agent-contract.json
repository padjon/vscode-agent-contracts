{
  "protectedPaths": [
    "**/.env*",
    "**/*.pem",
    ".github/workflows/**",
    "terraform/**",
    "infra/**",
    "prod/**"
  ],
  "requiredVerification": [
    "terraform fmt -check",
    "terraform validate"
  ],
  "blockedCommands": [
    "git push --force",
    "rm -rf /",
    "curl | sh"
  ],
  "blockedMcpServers": [],
  "allowedMcpHosts": [],
  "allowedMcpRunnerTargets": [],
  "severityOverrides": [],
  "notes": "Starter policy for Terraform and infrastructure repositories."
}
